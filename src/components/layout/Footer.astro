---
import { personal } from '../../data/portfolio.js';
---

<footer class="footer" role="contentinfo">
  <div class="footer__inner">
    <p class="footer__copy">
      &copy; {new Date().getFullYear()} &mdash; <span class="footer__name">{personal.name}</span>
    </p>
    <p class="footer__stack">
      Hecho con <span class="footer__tech" translate="no">Astro</span> &amp; <span class="footer__tech" translate="no">TypeScript</span>
    </p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem 1rem;
    background: var(--color-bg-secondary);
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    text-align: center;
  }

  .footer__copy {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .footer__name {
    color: var(--color-accent-neon);
    font-weight: 600;
  }

  .footer__stack {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    opacity: 0.7;
  }

  .footer__tech {
    font-family: var(--font-code);
    font-size: 0.78rem;
  }
</style>
