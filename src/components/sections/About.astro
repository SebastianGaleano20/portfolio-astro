---
import { personal } from '../../data/portfolio.js';

const stats = [
  { value: "+2",   label: "Años de experiencia" },
  { value: "4+",   label: "Proyectos en producción" },
  { value: "15+",  label: "Tecnologías dominadas" },
  { value: "100%", label: "Autodidacta & apasionado" },
];
---

<section class="section about" id="about" aria-labelledby="about-title">
  <div class="container">
    <div class="about__header reveal">
      <h2 class="section-title" id="about-title">Sobre <span>mí</span></h2>
      <div class="section-divider" role="presentation"></div>
      <p class="section-subtitle">Un poco de contexto sobre quién soy y qué hago</p>
    </div>

    <div class="about__grid">
      <div class="about__text reveal reveal-delay-1">
        <p class="about__bio">{personal.bio}</p>

        <p class="about__focus">
          Me enfoco en construir aplicaciones que combinen
          <span class="highlight-neon">rendimiento técnico</span> con una
          experiencia de usuario memorable — desde el diseño de la UI hasta
          la arquitectura del backend.
        </p>

        <div class="about__tags">
          {["Clean Code", "SOLID Principles", "REST APIs", "Mobile-first", "Agile"].map((tag) => (
            <span class="about__tag"># {tag}</span>
          ))}
        </div>

        <div class="about__cta-row">
          <a
            href={personal.github}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-outline"
            aria-label="Ver perfil de GitHub"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            GitHub Profile
          </a>
        </div>
      </div>

      <div class="about__stats reveal reveal-delay-2" role="list" aria-label="Key statistics">
        {stats.map((stat) => (
          <div class="about__stat glass-card" role="listitem">
            <span class="about__stat-value highlight-neon">{stat.value}</span>
            <span class="about__stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .about__header {
    margin-bottom: 3rem;
  }

  .about__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .about__text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .about__bio,
  .about__focus {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.75;
  }

  .about__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .about__tag {
    font-family: var(--font-code);
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    background: rgba(42, 74, 107, 0.3);
    border: 1px solid var(--color-border);
    padding: 0.3rem 0.7rem;
    border-radius: var(--radius-sm);
  }

  .about__cta-row {
    margin-top: 0.5rem;
  }

  .about__stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .about__stat {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.4rem;
  }

  .about__stat-value {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
  }

  .about__stat-label {
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    line-height: 1.3;
  }

  @media (max-width: 1024px) {
    .about__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  @media (max-width: 480px) {
    .about__stats {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
