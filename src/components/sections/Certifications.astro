---
import { certifications } from '../../data/portfolio.js';
---

<section class="section certs" id="certifications" aria-labelledby="certs-title">
  <div class="container">
    <div class="certs__header reveal">
      <h2 class="section-title" id="certs-title">Certificaciones <span>&amp; formación</span></h2>
      <div class="section-divider" role="presentation"></div>
      <p class="section-subtitle">Aprendizaje continuo respaldado por instituciones reconocidas</p>
    </div>

    <div class="certs__timeline">
      {certifications.map((cert, certIndex) => (
        <div class={`certs__group reveal reveal-delay-${certIndex + 1}`}>
          <div class="certs__timeline-dot" aria-hidden="true"></div>

          <div class="certs__group-header">
            <div class="certs__group-meta">
              <h3 class="certs__entity">{cert.entity}</h3>
              <span class="certs__year">{cert.year}</span>
            </div>
          </div>

          <div class="certs__courses">
            {cert.courses.map((course) => (
              <article class="cert-card glass-card" aria-label={`${course.name} — ${cert.entity}`}>
                {course.image && (
                  <button
                    class="cert-card__image-wrap"
                    data-img-src={course.image}
                    data-img-alt={`Certificado ${course.name} — ${cert.entity}`}
                    aria-label={`Ampliar certificado ${course.name}`}
                    title="Clic para ampliar"
                  >
                    <img
                      src={course.image}
                      alt={`Certificado ${course.name}`}
                      class="cert-card__image"
                      loading="lazy"
                    />
                    <div class="cert-card__zoom-hint" aria-hidden="true">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        <line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/>
                      </svg>
                      Ampliar
                    </div>
                  </button>
                )}
                <div class="cert-card__body">
                  <h4 class="cert-card__name">{course.name}</h4>
                  <div class="cert-card__topics" role="list" aria-label="Temas cubiertos">
                    {course.topics.map((topic) => (
                      <span class="cert-card__topic tech-tag" role="listitem">{topic}</span>
                    ))}
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<div
  class="cert-modal"
  id="certModal"
  role="dialog"
  aria-modal="true"
  aria-label="Certificado ampliado"
  hidden
>
  <div class="cert-modal__backdrop" id="certModalBackdrop" aria-hidden="true"></div>
  <div class="cert-modal__content">
    <button class="cert-modal__close" id="certModalClose" aria-label="Cerrar imagen">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    <img class="cert-modal__image" id="certModalImage" src="" alt="" />
  </div>
</div>

<script>
  const modal         = document.getElementById('certModal');
  const modalImage    = document.getElementById('certModalImage');
  const modalClose    = document.getElementById('certModalClose');
  const modalBackdrop = document.getElementById('certModalBackdrop');

  function openModal(src, alt) {
    modalImage.src = src;
    modalImage.alt = alt;
    modal.hidden = false;
    document.body.style.overflow = 'hidden';
    modalClose?.focus();
  }

  function closeModal() {
    modal.hidden = true;
    document.body.style.overflow = '';
    modalImage.src = '';
  }

  document.querySelectorAll('.cert-card__image-wrap').forEach((btn) => {
    btn.addEventListener('click', () => {
      const src = btn.dataset.imgSrc ?? '';
      const alt = btn.dataset.imgAlt ?? '';
      if (src) openModal(src, alt);
    });
  });

  modalClose?.addEventListener('click', closeModal);
  modalBackdrop?.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.hidden) closeModal();
  });
</script>

<style>
  .certs__header {
    margin-bottom: 3rem;
  }

  .certs__timeline {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 3rem;
    padding-left: 2.5rem;
  }

  .certs__timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 12px;
    bottom: 12px;
    width: 2px;
    background: linear-gradient(
      to bottom,
      var(--color-accent-neon),
      var(--color-border),
      transparent
    );
  }

  .certs__group {
    position: relative;
  }

  .certs__timeline-dot {
    position: absolute;
    left: -2.5rem;
    top: 6px;
    transform: translateX(-50%);
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-accent-neon);
    border: 2px solid var(--color-bg-primary);
    box-shadow: 0 0 10px rgba(0, 255, 136, 0.5);
  }

  .certs__group-header {
    margin-bottom: 1.25rem;
    padding-left: 0.25rem;
  }

  .certs__group-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .certs__entity {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .certs__year {
    font-family: var(--font-code);
    font-size: 0.8rem;
    color: var(--color-accent-neon);
    background: rgba(0, 255, 136, 0.08);
    border: 1px solid rgba(0, 255, 136, 0.2);
    padding: 0.15rem 0.6rem;
    border-radius: var(--radius-sm);
  }

  .certs__courses {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
  }

  .cert-card {
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .cert-card__image-wrap {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-bg-secondary);
    border-bottom: 1px solid var(--color-border);
    cursor: pointer;
    border: none;
    padding: 0;
  }

  .cert-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow), filter var(--transition-normal);
    display: block;
  }

  .cert-card__image-wrap:hover .cert-card__image {
    transform: scale(1.04);
    filter: brightness(0.65);
  }

  .cert-card__zoom-hint {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    color: var(--color-accent-neon);
    font-size: 0.78rem;
    font-weight: 600;
    opacity: 0;
    transition: opacity var(--transition-normal);
    pointer-events: none;
  }

  .cert-card__image-wrap:hover .cert-card__zoom-hint {
    opacity: 1;
  }

  .cert-card__body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .cert-card__name {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .cert-card__topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .cert-card__topic {
    font-size: 0.68rem;
  }

  /* ─── Modal ────────────────────────────────────────── */
  .cert-modal {
    position: fixed;
    inset: 0;
    z-index: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }

  .cert-modal[hidden] {
    display: none;
  }

  .cert-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(5, 10, 20, 0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .cert-modal__content {
    position: relative;
    z-index: 1;
    max-width: min(90vw, 900px);
    max-height: 90vh;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow:
      0 0 60px rgba(0, 0, 0, 0.8),
      0 0 0 1px rgba(0, 255, 136, 0.1);
    animation: fadeInUp 0.25s ease;
  }

  .cert-modal__image {
    display: block;
    max-width: 100%;
    max-height: 85vh;
    object-fit: contain;
    background: var(--color-bg-secondary);
  }

  .cert-modal__close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 2;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(10, 15, 30, 0.85);
    border: 1px solid var(--color-border);
    color: var(--color-text-primary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast),
      color var(--transition-fast);
  }

  .cert-modal__close:hover {
    background: rgba(0, 255, 136, 0.15);
    border-color: var(--color-accent-neon);
    color: var(--color-accent-neon);
  }

  @media (max-width: 768px) {
    .certs__timeline {
      padding-left: 1.75rem;
    }

    .certs__timeline-dot {
      left: -1.75rem;
    }

    .certs__courses {
      grid-template-columns: 1fr;
    }
  }
</style>
