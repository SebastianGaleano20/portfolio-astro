---
import { personal } from '../../data/portfolio.js';
---

<section class="hero" id="hero" aria-label="Hero section">
  <div class="hero__bg" aria-hidden="true">
    <div class="hero__glow hero__glow--left"></div>
    <div class="hero__glow hero__glow--right"></div>
    <div class="hero__grid"></div>
  </div>

  <div class="container hero__inner">
    <div class="hero__content reveal">
      <p class="hero__greeting">
        <span class="hero__greeting-line" aria-hidden="true"></span>
        Hola, soy
      </p>

      <h1 class="hero__name">
        {personal.name.split(' ')[0]}<br />
        <span class="highlight-neon">{personal.name.split(' ')[1]}</span>
      </h1>

      <div class="hero__role" aria-live="polite">
        <span class="hero__role-prefix">&lt;</span>
        <span class="hero__typewriter" id="typewriter" aria-label={`Role: ${personal.role}`}></span>
        <span class="hero__cursor" aria-hidden="true">|</span>
        <span class="hero__role-suffix"> /&gt;</span>
      </div>

      <p class="hero__bio reveal reveal-delay-2">
        {personal.bio}
      </p>

      <div class="hero__actions reveal reveal-delay-3">
        <a href="#projects" class="btn-primary" aria-label="Ver mis proyectos">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="16 18 22 12 16 6"/>
            <polyline points="8 6 2 12 8 18"/>
          </svg>
          Ver Proyectos
        </a>
        <a href="#contact" class="btn-outline" aria-label="Ir a contacto">
          Contacto
        </a>
      </div>

      <div class="hero__socials reveal reveal-delay-4">
        <a href={personal.github} target="_blank" rel="noopener noreferrer" class="hero__social-link" aria-label="GitHub profile">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <a href={personal.linkedin} target="_blank" rel="noopener noreferrer" class="hero__social-link" aria-label="LinkedIn profile">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a href={`mailto:${personal.email}`} class="hero__social-link" aria-label="Send email">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="hero__code-card reveal reveal-delay-2" aria-hidden="true">
      <div class="hero__code-header">
        <span class="hero__code-dot hero__code-dot--red"></span>
        <span class="hero__code-dot hero__code-dot--yellow"></span>
        <span class="hero__code-dot hero__code-dot--green"></span>
        <span class="hero__code-filename">developer.ts</span>
      </div>
      <pre class="hero__code-body"><code><span class="code-keyword">const</span> <span class="code-var">developer</span> <span class="code-op">=</span> <span class="code-brace">&#123;</span>
  <span class="code-key">name</span><span class="code-op">:</span>  <span class="code-string">"Sebastian Galeano"</span><span class="code-op">,</span>
  <span class="code-key">role</span><span class="code-op">:</span>  <span class="code-string">"FullStack Dev"</span><span class="code-op">,</span>
  <span class="code-key">stack</span><span class="code-op">:</span> <span class="code-brace">[</span>
    <span class="code-string">"React"</span><span class="code-op">,</span> <span class="code-string">"Next.js"</span><span class="code-op">,</span>
    <span class="code-string">"Node.js"</span><span class="code-op">,</span> <span class="code-string">"PostgreSQL"</span>
  <span class="code-brace">]</span><span class="code-op">,</span>
  <span class="code-key">passion</span><span class="code-op">:</span> <span class="code-string">"clean code"</span><span class="code-op">,</span>
  <span class="code-key">status</span><span class="code-op">:</span>  <span class="code-neon">"available"</span>
<span class="code-brace">&#125;</span></code></pre>
    </div>
  </div>

  <a href="#about" class="hero__scroll-cta" aria-label="Scroll down to about section">
    <span>Scroll</span>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="6 9 12 15 18 9"/>
    </svg>
  </a>
</section>

<script define:vars={{ roles: personal.typewriterRoles }}>
  const el       = document.getElementById('typewriter');
  let roleIndex  = 0;
  let charIndex  = 0;
  let deleting   = false;

  function type() {
    const current = roles[roleIndex];

    if (!deleting) {
      if (el) el.textContent = current.slice(0, charIndex + 1);
      charIndex++;
      if (charIndex === current.length) {
        deleting = true;
        setTimeout(type, 1800);
        return;
      }
    } else {
      if (el) el.textContent = current.slice(0, charIndex - 1);
      charIndex--;
      if (charIndex === 0) {
        deleting = false;
        roleIndex = (roleIndex + 1) % roles.length;
      }
    }

    setTimeout(type, deleting ? 60 : 90);
  }

  type();
</script>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Background */
  .hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero__glow {
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.12;
  }

  .hero__glow--left {
    background: var(--color-accent-neon);
    top: -100px;
    left: -200px;
  }

  .hero__glow--right {
    background: #0080ff;
    bottom: -100px;
    right: -200px;
  }

  .hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(26, 58, 92, 0.15) 1px, transparent 1px),
      linear-gradient(90deg, rgba(26, 58, 92, 0.15) 1px, transparent 1px);
    background-size: 50px 50px;
    mask-image: radial-gradient(ellipse at center, black 20%, transparent 80%);
  }

  /* Inner layout */
  .hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
    padding-top: var(--navbar-height);
  }

  /* Content */
  .hero__content {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero__greeting {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  .hero__greeting-line {
    display: inline-block;
    width: 30px;
    height: 1px;
    background: var(--color-accent-neon);
  }

  .hero__name {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-family: var(--font-heading);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  .hero__role {
    font-family: var(--font-code);
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    gap: 0.1rem;
  }

  .hero__role-prefix,
  .hero__role-suffix {
    color: var(--color-metallic);
  }

  .hero__typewriter {
    color: var(--color-accent-neon);
    min-width: 1ch;
  }

  .hero__cursor {
    color: var(--color-accent-neon);
    animation: blink 1s step-end infinite;
  }

  .hero__bio {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 480px;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero__socials {
    display: flex;
    gap: 1rem;
    padding-top: 0.5rem;
  }

  .hero__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-secondary);
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast),
      box-shadow var(--transition-fast),
      transform var(--transition-fast);
  }

  .hero__social-link:hover {
    color: var(--color-accent-neon);
    border-color: var(--color-accent-neon);
    box-shadow: 0 0 10px rgba(0, 255, 136, 0.2);
    transform: translateY(-2px);
  }

  /* Code card */
  .hero__code-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    animation: float 6s ease-in-out infinite;
  }

  .hero__code-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.75rem 1rem;
    background: var(--color-bg-secondary);
    border-bottom: 1px solid var(--color-border);
  }

  .hero__code-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .hero__code-dot--red    { background: #ff5f57; }
  .hero__code-dot--yellow { background: #ffbd2e; }
  .hero__code-dot--green  { background: #28ca41; }

  .hero__code-filename {
    font-family: var(--font-code);
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    margin-left: 0.5rem;
  }

  .hero__code-body {
    padding: 1.5rem;
    font-family: var(--font-code);
    font-size: 0.85rem;
    line-height: 1.8;
    overflow-x: auto;
  }

  .code-keyword { color: #c586c0; }
  .code-var     { color: #9cdcfe; }
  .code-op      { color: var(--color-text-secondary); }
  .code-brace   { color: #ffd700; }
  .code-key     { color: #9cdcfe; }
  .code-string  { color: #ce9178; }
  .code-neon    { color: var(--color-accent-neon); }

  /* Scroll CTA */
  .hero__scroll-cta {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    animation: float 2.5s ease-in-out infinite;
    transition: color var(--transition-fast);
    z-index: 1;
  }

  .hero__scroll-cta:hover {
    color: var(--color-accent-neon);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .hero__inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3rem;
    }

    .hero__greeting,
    .hero__actions,
    .hero__socials,
    .hero__role {
      justify-content: center;
    }

    .hero__bio {
      margin: 0 auto;
    }

    .hero__code-card {
      max-width: 420px;
      margin: 0 auto;
    }
  }

  @media (max-width: 480px) {
    .hero__name {
      font-size: 2.5rem;
    }

    .hero__actions {
      flex-direction: column;
    }

    .hero__actions a {
      text-align: center;
      justify-content: center;
    }
  }
</style>
