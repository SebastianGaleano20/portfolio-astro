---
interface Props {
  name: string;
  description: string;
  bullets: string[];
  tech: string[];
  github: string;
  live: string;
  image: string;
}

const { name, description, bullets, tech, github, live, image } = Astro.props;
---

<article class="project-card glass-card" role="article">
  <div class="project-card__image-wrap">
    <img
      src={image}
      alt={`${name} screenshot`}
      class="project-card__image"
      loading="lazy"
    />
    <div class="project-card__overlay">
      <a href={live} target="_blank" rel="noopener noreferrer" class="project-card__link btn-primary" aria-label={`Ver ${name} en vivo`}>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
          <polyline points="15 3 21 3 21 9"/>
          <line x1="10" y1="14" x2="21" y2="3"/>
        </svg>
        Live
      </a>
      <a href={github} target="_blank" rel="noopener noreferrer" class="project-card__link btn-outline" aria-label={`Ver código de ${name}`}>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        Code
      </a>
    </div>
  </div>

  <div class="project-card__body">
    <h3 class="project-card__name">{name}</h3>
    <p class="project-card__desc">{description}</p>

    <ul class="project-card__bullets" role="list">
      {bullets.map((bullet) => (
        <li class="project-card__bullet">
          <span class="project-card__bullet-dot" aria-hidden="true">▹</span>
          {bullet}
        </li>
      ))}
    </ul>

    <div class="project-card__tech" role="list" aria-label="Technologies used">
      {tech.map((t) => (
        <span class="tech-tag" role="listitem">{t}</span>
      ))}
    </div>
  </div>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .project-card__image-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-bg-secondary);
  }

  .project-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .project-card:hover .project-card__image {
    transform: scale(1.05);
  }

  .project-card__overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 15, 30, 0.85);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    opacity: 0;
    transition: opacity var(--transition-normal);
  }

  .project-card:hover .project-card__overlay {
    opacity: 1;
  }

  .project-card__link {
    font-size: 0.82rem;
    padding: 0.6rem 1.2rem;
  }

  .project-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .project-card__name {
    font-size: 1.1rem;
    font-family: var(--font-heading);
    color: var(--color-text-primary);
  }

  .project-card__desc {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .project-card__bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .project-card__bullet {
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
    line-height: 1.5;
  }

  .project-card__bullet-dot {
    color: var(--color-accent-neon);
    flex-shrink: 0;
    font-size: 0.75rem;
    margin-top: 0.1rem;
  }

  .project-card__tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: auto;
    padding-top: 0.5rem;
  }
</style>
